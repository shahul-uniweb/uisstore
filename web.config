<?xml version="1.0" encoding="utf-8"?>
<!--
  SmarterASP.NET (IIS) → Node.js via httpPlatformHandler.

  IIS starts the Node process itself and reverse-proxies every request to it on
  the port it hands us in %HTTP_PLATFORM_PORT%. The Nitro server reads that from
  process.env.PORT and serves BOTH the SSR HTML and the static assets in
  dist/client, so all requests are forwarded to Node — no static rules needed.

  processPath points at node.exe directly rather than npm.cmd: npm spawns Node as
  a *child* process, so IIS ends up monitoring the npm wrapper instead of the real
  server, which makes shutdown/restart flaky and can break port binding.
-->
<configuration>
  <system.webServer>

    <handlers>
      <!-- Remove any inherited handler first, so this one definitely wins. -->
      <remove name="httpPlatformHandler" />
      <add name="httpPlatformHandler"
           path="*"
           verb="*"
           modules="httpPlatformHandler"
           resourceType="Unspecified"
           requireAccess="Script" />
    </handlers>

    <httpPlatform
        processPath="C:\Program Files\nodejs\node.exe"
        arguments=".\dist\server\index.mjs"
        startupTimeLimit="120"
        startupRetryCount="3"
        requestTimeout="00:04:00"
        stdoutLogEnabled="true"
        stdoutLogFile=".\logs\stdout">

      <environmentVariables>
        <!-- IIS picks a free port and tells us which one to listen on. -->
        <environmentVariable name="PORT" value="%HTTP_PLATFORM_PORT%" />
        <environmentVariable name="HOST" value="127.0.0.1" />
        <environmentVariable name="NODE_ENV" value="production" />
      </environmentVariables>

    </httpPlatform>

    <!-- Let the Node app's own error/404 responses through untouched. -->
    <httpErrors existingResponse="PassThrough" />

  </system.webServer>
</configuration>
