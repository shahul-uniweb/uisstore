<?xml version="1.0" encoding="utf-8"?>
<!--
  IIS config for hosting the Node SSR build on SmarterASP.NET (iisnode).

  Only needed if SmarterASP.NET runs the app through IIS/iisnode. If their panel
  accepts a "Start Command" and manages the Node process for you, that command
  (`npm start`) is enough and this file is ignored.

  The Nitro server already serves the static assets from dist/client itself, so
  every request is simply forwarded to it.
-->
<configuration>
  <system.webServer>
    <handlers>
      <add name="iisnode" path="dist/server/index.mjs" verb="*" modules="iisnode" />
    </handlers>

    <rewrite>
      <rules>
        <!-- Let iisnode's own debug/console endpoints through untouched. -->
        <rule name="NodeInspector" patternSyntax="ECMAScript" stopProcessing="true">
          <match url="^dist/server/index.mjs\/debug[\/]?" />
        </rule>

        <!-- Everything else goes to the Node SSR server (it serves assets too). -->
        <rule name="DynamicContent">
          <match url="/*" />
          <action type="Rewrite" url="dist/server/index.mjs" />
        </rule>
      </rules>
    </rewrite>

    <iisnode
      nodeProcessCommandLine="node"
      watchedFiles="web.config;*.js;*.mjs"
      loggingEnabled="true"
      devErrorsEnabled="false"
    />

    <!-- Don't let IIS try to serve these itself. -->
    <security>
      <requestFiltering>
        <hiddenSegments>
          <add segment="node_modules" />
          <add segment="src" />
        </hiddenSegments>
      </requestFiltering>
    </security>

    <httpErrors existingResponse="PassThrough" />
  </system.webServer>
</configuration>
