# The pinned `nitro` version is older than the peer range @lovable.dev/vite-tanstack-config
# asks for, which makes a plain `npm install` fail with ERESOLVE. Bun (the project's
# normal package manager) doesn't care, but hosts like SmarterASP.NET run npm — so
# relax peer resolution to keep their build step working.
legacy-peer-deps=true
